adr "0017" "Implement Architecture Tests"

rule "archtests_project_exists" {
  path "src/Tests/ArchTests/*.csproj" must exist
  severity error
}

rule "netarchtest_is_referenced_centrally" {
  path "src/Directory.Packages.props" must contain "regex:PackageReference Include=\"NetArchTest\\.Rules\""
  severity error
}
