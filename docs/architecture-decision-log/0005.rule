adr "0005" "Create one REST API module"

file "single_api_project_exists" {
  path "API/**/CompanyName.MyMeetings.API.csproj" must exist
  severity error
}

file "no_module_api_projects" {
  # ensure there are no separate API projects inside modules
  path "Modules/**/**API**.csproj" must not exist
  severity warning
}
