}

rule "registrations_isolated_from_payments" {
  Registrations must not depend_on Payments
  exclude class implementing interface "MediatR.INotificationHandler<>"
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
}

rule "registrations_isolated_from_userAccess" {
  Registrations must not depend_on UserAccess
  exclude class implementing interface "MediatR.INotificationHandler<>"
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
