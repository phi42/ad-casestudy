adr "0014" "Event-driven communication between modules"

# modules (namespace roots)
component "UserAccess"      = "CompanyName.MyMeetings.Modules.UserAccess"
component "Meetings"        = "CompanyName.MyMeetings.Modules.Meetings"
component "Administration"  = "CompanyName.MyMeetings.Modules.Administration"
component "Payments"        = "CompanyName.MyMeetings.Modules.Payments"
component "Registrations"   = "CompanyName.MyMeetings.Modules.Registrations"

# isolation rules: modules must not depend on each other (pairwise)
# Note: Exclusions filter out infrastructure/integration code from the check

rule "userAccess_isolated_from_meetings" {
  UserAccess must not depend_on Meetings
  exclude class implementing interface "MediatR.INotificationHandler<>"
  # Note: old syntax supported 'name_ends_with "IntegrationEventHandler"' - now using direct match
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
}

rule "userAccess_isolated_from_administration" {
  UserAccess must not depend_on Administration
  exclude class implementing interface "MediatR.INotificationHandler<>"
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
}

rule "userAccess_isolated_from_payments" {
  UserAccess must not depend_on Payments
  exclude class implementing interface "MediatR.INotificationHandler<>"
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
}

rule "meetings_isolated_from_administration" {
  Meetings must not depend_on Administration
  exclude class implementing interface "MediatR.INotificationHandler<>"
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
}

rule "meetings_isolated_from_payments" {
  Meetings must not depend_on Payments
  exclude class implementing interface "MediatR.INotificationHandler<>"
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
}

rule "administration_isolated_from_payments" {
  Administration must not depend_on Payments
  exclude class implementing interface "MediatR.INotificationHandler<>"
  exclude class "IntegrationEventHandler"
  exclude class "EventsBusStartup"
  severity error
}

