adr "0004" "Divide the system into 4 modules"

file "modules_exist" {
  path "src/Modules/Meetings/" must exist
  path "src/Modules/Administration/" must exist
  path "src/Modules/Payments/" must exist
  path "src/Modules/UserAccess/" must exist
  severity error
}

file "building_blocks_exist" {
  path "src/BuildingBlocks/" must exist
  severity warning
}

# dependencies between modules should not be allowed
