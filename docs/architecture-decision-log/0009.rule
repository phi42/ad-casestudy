adr "0009" "Use 2 layered architectural style for reads"

file "query_handlers_in_application_layer" {
  path "src/Modules/**/Application/**/*QueryHandler.cs" must exist
  severity error
}

file "no_query_handlers_in_domain" {
  path "src/Modules/**/Domain/**/*Query*.cs" must not exist
  severity warning
}

file "api_has_query_endpoints" {
  path "src/API/**/*Controller.cs" must exist
  severity error
}
