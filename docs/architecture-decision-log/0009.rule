adr "0009" "Use 2 layered architectural style for reads"

file "query_handlers_in_application_layer" {
  path "Modules/**/Application/**/*QueryHandler.cs" must exist
  severity error
}

file "no_query_in_domain" {
  path "Modules/**/Domain/**/*Query.cs" must not exist
  severity error
}

file "api_has_query_endpoints" {
  path "API/**/*Controller.cs" must exist
  severity error
}
